# Database Configuration
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=celume_ai_workspace

# Server Configuration
PORT=4000
NODE_ENV=development

# Frontend API Configuration
# Leave blank in local Vite dev to use the /api proxy.
# Set this when the frontend and backend run on different hosts.
VITE_API_BASE_URL=

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
